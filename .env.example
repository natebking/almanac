# DUMMY CONFIG TEMPLATE ONLY.
# Copy this file to .env and replace placeholders with your own project values.
# Do not put real secrets, personal emails, tenant data, or owner data in source control.

DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./prisma/dev.db"
AUTH_SECRET="replace-with-32-plus-random-characters"
AUTH_MODE="alpha"
ALMANAC_ALLOWED_EMAILS=""
APP_URL="http://localhost:3000"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"
GOOGLE_MODE="local"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"
GOOGLE_OPTIONAL_DIAGNOSTICS="disabled"
GOOGLE_TEST_ROOT_FOLDER_ID=""
GOOGLE_MASTER_SPREADSHEET_ID=""
GOOGLE_MASTER_SHEET_NAME="Rentals"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"
