{
  "name": "almanac-property-hub",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-generate.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "alpha:clerk-access": "tsx scripts/almanac-clerk-access-readiness.ts",
    "alpha:invite-user": "tsx scripts/almanac-invite-alpha-user.ts",
    "alpha:readiness": "tsx scripts/almanac-alpha-readiness.ts",
    "alpha:fixture-manifest": "tsx scripts/almanac-fixture-manifest.ts",
    "alpha:fixture-bundle": "tsx scripts/almanac-fixture-upload-bundle.ts",
    "alpha:google-oauth": "tsx scripts/almanac-google-oauth-setup.ts",
    "alpha:hosted-smoke": "tsx scripts/almanac-hosted-smoke.ts",
    "alpha:seed-hosted-dummy": "node scripts/prisma-generate.mjs && tsx scripts/almanac-seed-hosted-dummy.ts",
    "handoff:operator": "node scripts/create-operator-handoff-package.mjs",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:generate:sqlite": "prisma generate --schema=prisma/schema.prisma",
    "db:generate:postgres": "prisma generate --schema=prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev",
    "db:push:postgres": "prisma db push --schema=prisma/schema.postgres.prisma",
    "db:reset-local": "rm -f prisma/dev.db && for migration in prisma/migrations/*/migration.sql; do sqlite3 prisma/dev.db < \"$migration\"; done && npm run db:generate:sqlite",
    "db:seed": "tsx prisma/seed.ts",
    "db:init": "npm run db:reset-local && npm run db:seed"
  },
  "dependencies": {
    "@clerk/backend": "^3.8.0",
    "@clerk/nextjs": "^7.5.4",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.13"
    },
    "next": {
      "postcss": "8.5.10"
    }
  }
}
